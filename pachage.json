{
    "name": "dungeon-master-hub",
    "version": "1.0.0",
    "description": "Centralized hub for Dungeons & Dragons resources and tools.",
    "main": "main.js",
    "scripts": {
        "start": "vite",
        "preview": "vite preview",
        "build": "vite build --emptyOutDir",
        "lint": "eslint *.js src/**/*.js",
        "format": "prettier --ignore-path ./.gitignore --write \"./**/*.{html,json,js,ts,css}\"",
        "test": "jest"
    },
    "author": "Joshua Smith",
    "devDependencies": {
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^8.10.0",
        "eslint-plugin-import": "^2.29.1",
        "jest": "^29.7.0",
        "prettier": "^3.2.5",
        "vite": "^5.4.7"
    },
    "babel": {
        "presets": [
            "@babel/preset-env"
        ]
    },
    "brouserlist": [
        "last 3 and_chr versions",
        "last 3 chrome versions",
        "last 3 opera versions",
        "last 3 ion_saf versions",
        "last 3 safari versions"
    ]
}